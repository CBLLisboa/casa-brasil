# ===========================================
# Casa do Brasil - Variáveis de ambiente
# ===========================================
# Copie para .env e preencha os valores.
# No Railway: DATABASE_URL é preenchido automaticamente.
# ===========================================

PORT=5000
NODE_ENV=development

# Base de dados (local) - ou use DATABASE_URL no Railway
DB_HOST=localhost
DB_PORT=5432
DB_NAME=casa_brasil_lisboa
DB_USER=postgres
DB_PASSWORD=sua_senha

# Railway/cloud: use DATABASE_URL (preenchido automaticamente ao adicionar PostgreSQL)

# Autenticação
JWT_SECRET=uma_senha_longa_e_segura_min_32_caracteres
JWT_EXPIRES_IN=24h

# Email (recuperação de senha)
ADMIN_EMAIL=admin@casabrasil.pt
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_de_app
SMTP_SECURE=false
SMTP_FROM=Casa do Brasil <seu_email@gmail.com>

# URL pública (produção) - ex: https://casa-brasil.up.railway.app
APP_BASE_URL=http://localhost:5000

RESET_TOKEN_MINUTES=60
